# =============================================================================
# PostgreSQL + Ollama Embeddings + OpenAI Summary Configuration (REQUIRED)
# =============================================================================
# For use with: docker-compose.postgresql.ollama-openai.yml or docker-compose.postgresql.ollama-openai.local.yml
#
# Copy to .env and configure your OpenAI API key.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: OpenAI API Key (for summary generation)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------------------
# Optional: LangSmith Tracing
# -----------------------------------------------------------------------------
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_your-langsmith-api-key
# LANGSMITH_PROJECT=mcp-context-server

# -----------------------------------------------------------------------------
# Optional: FastMCP Logging (recommended for Docker/cloud deployments)
# -----------------------------------------------------------------------------
# Disable Rich log formatting to prevent multi-line wrapping in container logs
# FASTMCP_ENABLE_RICH_LOGGING=false

# -----------------------------------------------------------------------------
# Optional: Logging Configuration
# -----------------------------------------------------------------------------
# LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# Optional: Model Configuration
# -----------------------------------------------------------------------------
# Uncomment to override the default models for this deployment.
# Defaults shown below match the compose file defaults.
# EMBEDDING_MODEL=qwen3-embedding:0.6b
# EMBEDDING_DIM=1024
# SUMMARY_MODEL=gpt-5.4-nano

# -----------------------------------------------------------------------------
# Optional: PostgreSQL Credentials
# -----------------------------------------------------------------------------
# Override the default PostgreSQL credentials used by the bundled postgres service.
# POSTGRESQL_USER=postgres
# POSTGRESQL_PASSWORD=postgres
# POSTGRESQL_DATABASE=mcp_context

# -----------------------------------------------------------------------------
# Optional: PostgreSQL Connection Pool Settings
# -----------------------------------------------------------------------------
# POSTGRESQL_POOL_MIN=2
# POSTGRESQL_POOL_MAX=20
